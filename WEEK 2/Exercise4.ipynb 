      "source": [
        "# This will remove the dollar sign from the `item_price` column and convert the cleaned values into floats.\n",
        "\n",
        "chipo[\"item_price\"] = chipo[\"item_price\"].str.replace('$', '').astype(float)\n",
        "\n",
        "# This will create a new column in the chipo DataFrame called (product_price) and stores the unit price there.\n",
        "\n",
        "chipo[\"product_price\"] = chipo[\"item_price\"] / chipo[\"quantity\"]\n",
        "chipo"
      ]
